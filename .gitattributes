* text=auto
.gitattributes text eol=lf

# MATLAB source
*.m text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf

# Structured text / data
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.csv text eol=lf

# Shell scripts
*.sh text eol=lf

# Windows scripts
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.mat binary
*.fig binary
*.png binary
*.jpg binary
*.pdf binary
*.zip binary
*.eps binary
*.svg binary
*.xlsx binary